<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统登录"
        Width="1300" Height="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="微软雅黑"
        Background="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧插画铺满背景 -->
        <Border Grid.Column="0">
            <Border.Background>
                <ImageBrush ImageSource="1.png" Stretch="Fill"/>
            </Border.Background>
        </Border>

        <!-- 右侧登录表单区域 -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="540">
            <TextBlock Text="XX后台管理系统" FontSize="46" FontWeight="Bold" Foreground="#222222" Margin="0 0 0 50"/>

            <!-- 用户名输入框，文字垂直居中、可正常输入 -->
            <TextBlock Text="用户名" FontSize="17" Foreground="#333" Margin="0 0 0 10"/>
            <TextBox x:Name="txtUserName" Text="admin" Height="50" FontSize="16" Margin="0 0 0 24"
                     VerticalContentAlignment="Center" TextChanged="txtUserName_TextChanged">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="#C8C8C8" BorderThickness="1" CornerRadius="4">
                            <Grid Margin="12 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="👤" FontSize="18" VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" Margin="8 0"/>
                                <Button x:Name="btnClearUser" Grid.Column="2" Content="✕" Width="24" Height="24"
                                        Background="Transparent" BorderThickness="0" Foreground="#777"
                                        Click="BtnClearUser_Click"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>

            <!-- 密码输入框 -->
            <TextBlock Text="密码" FontSize="17" Foreground="#333" Margin="0 0 0 10"/>
            <PasswordBox x:Name="pwdBox" Password="123456" Height="50" FontSize="16" Margin="0 0 0 16"
                         VerticalContentAlignment="Center">
                <PasswordBox.Template>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border BorderBrush="#C8C8C8" BorderThickness="1" CornerRadius="4">
                            <Grid Margin="12 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔒" FontSize="18" VerticalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" Margin="8 0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </PasswordBox.Template>
            </PasswordBox>

            <!-- 记住我 默认不勾选，匹配截图 -->
            <CheckBox x:Name="chkRemember" IsChecked="False" Content="记住我" FontSize="16" Foreground="#333"
                      HorizontalAlignment="Left" Margin="0 0 0 36"/>

            <!-- 登录按钮：内置转圈动画、登录中文字 -->
            <Button x:Name="btnLogin" Height="58" FontSize="20" Foreground="White"
                    Background="#297BFF" BorderThickness="0"  Click="BtnLogin_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <Grid>
                                <!-- 默认状态：登录文字 -->
                                <StackPanel x:Name="panelNormal" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Visible">
                                    <TextBlock Text="登录"  VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- 加载状态：转圈 + 登录中... -->
                                <StackPanel x:Name="panelLoading" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed">
                                    <Border Width="20" Height="20" Margin="0 0 8 0" BorderThickness="2" BorderBrush="White" CornerRadius="10">
                                        <Border.Clip>
                                            <EllipseGeometry Center="10,10" RadiusX="10" RadiusY="10"/>
                                        </Border.Clip>
                                        <Border.OpacityMask>
                                            <LinearGradientBrush EndPoint="0,1">
                                                <GradientStop Offset="0.3" Color="Transparent"/>
                                                <GradientStop Offset="1" Color="White"/>
                                            </LinearGradientBrush>
                                        </Border.OpacityMask>
                                        <Border.RenderTransform>
                                            <RotateTransform CenterX="10" CenterY="10"/>
                                        </Border.RenderTransform>
                                        <Border.Triggers>
                                            <EventTrigger RoutedEvent="Border.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle"
                                                                         From="0" To="360" Duration="00:00:0.8"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <TextBlock Text="登录中..." VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- 底部文字链接 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 36 0 0">
                <TextBlock Text="忘记密码?" FontSize="16" Foreground="#297BFF" Cursor="Hand"
                           MouseLeftButtonDown="TxtForgetPwd_Click" Margin="0 0 40 0"/>
                <TextBlock Text="注册账号" FontSize="16" Foreground="#297BFF" Cursor="Hand"
                           MouseLeftButtonDown="TxtRegister_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>