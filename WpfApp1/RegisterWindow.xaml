<Window x:Class="WpfApp1.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="注册账号"
        Width="1300" Height="820"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid>
        <!-- 修正列定义：标准完整写法，移除简写 "*,*" -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧插画区域 -->
        <Border Grid.Column="0">
            <Border.Background>
                <ImageBrush ImageSource="1.png" Stretch="Fill"/>
            </Border.Background>
        </Border>

        <!-- 右侧注册表单区域 -->
        <StackPanel Grid.Column="1" Width="540" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="注册账号" FontSize="42" FontWeight="SemiBold" Foreground="#222" Margin="0 0 0 40"/>

            <!-- 用户名输入框 -->
            <TextBlock Text="用户名" FontSize="16" Foreground="#444" Margin="0 0 0 8"/>
            <TextBox x:Name="txtUserName" FontSize="16" Padding="12 10" Margin="0 0 0 22" BorderThickness="1" BorderBrush="#ddd">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="👤" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="×" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#999" Click="ClearUserName"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>

            <!-- 密码 -->
            <TextBlock Text="密码" FontSize="16" Foreground="#444" Margin="0 0 0 8"/>
            <PasswordBox x:Name="pwdPassword" FontSize="16" Padding="12 10" Margin="0 0 0 22" BorderThickness="1" BorderBrush="#ddd">
                <PasswordBox.Template>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔒" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </PasswordBox.Template>
            </PasswordBox>

            <!-- 确认密码 -->
            <TextBlock Text="确认密码" FontSize="16" Foreground="#444" Margin="0 0 0 8"/>
            <PasswordBox x:Name="pwdConfirm" FontSize="16" Padding="12 10" Margin="0 0 0 22" BorderThickness="1" BorderBrush="#ddd">
                <PasswordBox.Template>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔒" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </PasswordBox.Template>
            </PasswordBox>

            <!-- 手机号 -->
            <TextBlock Text="手机号" FontSize="16" Foreground="#444" Margin="0 0 0 8"/>
            <TextBox x:Name="txtPhone" FontSize="16" Padding="12 10" Margin="0 0 0 22" BorderThickness="1" BorderBrush="#ddd">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📱" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>

            <!-- 同意协议 -->
            <CheckBox x:Name="cbAgree" Content="我已阅读并同意用户协议" FontSize="14" Foreground="#555" Margin="0 0 0 30"/>

            <!-- 注册按钮：修复圆角，移除 Button 直接 CornerRadius，改用模板Border -->
            <Button x:Name="btnRegister" Content="注册" FontSize="18" Foreground="White" Height="56" BorderThickness="0" Click="BtnRegister_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2678ff"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <!-- 圆角写在内部Border -->
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1d68e0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- 返回登录链接 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 30 0 0">
                <TextBlock Text="已有账号？" FontSize="14" Foreground="#666"/>
                <TextBlock Text="去登录" FontSize="14" Foreground="#2678ff" Margin="6 0 0 0" Cursor="Hand" MouseLeftButtonDown="ToLoginWindow"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>