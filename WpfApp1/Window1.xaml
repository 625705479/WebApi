<Window x:Class="WpfApp1.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XX后台管理系统"
        Width="1600" Height="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="微软雅黑"
        Background="#F7F8FA">
    <!-- 唯一一处Window.Resources，所有资源全部放这里 -->
    <Window.Resources>
        <!-- 侧边菜单按钮模板 -->
        <ControlTemplate x:Key="SideMenuBtn" TargetType="RadioButton">
            <Border x:Name="bdRoot" Padding="{TemplateBinding Padding}" Background="Transparent" CornerRadius="6" Margin="8 4">
                <ContentPresenter VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="bdRoot" Property="Background" Value="#E8F3FF"/>
                    <Setter Property="Foreground" Value="#297BFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bdRoot" Property="Background" Value="#F0F7FF"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- 面包屑横向布局面板 -->
        <ItemsPanelTemplate x:Key="BreadPanel">
            <StackPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>

        <!-- 面包屑标签Item模板（带关闭按钮） -->
        <DataTemplate x:Key="BreadCrumbItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- 标签文字 -->
                <TextBlock Text="{Binding PageName}" FontSize="16" Cursor="Hand" MouseDown="BreadItem_MouseDown"/>
                <!-- 分隔符 -->
                <TextBlock Text=" / " Foreground="#CCC" Margin="6 0"/>
                <!-- 关闭按钮（工作台隐藏关闭） -->
                <Button x:Name="btnClose" Content="×" Width="18" Height="18" FontSize="12" Background="Transparent" Foreground="#999" Click="CloseBreadItem_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEE"/>
                                    <Setter Property="Foreground" Value="#F53F3F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            <DataTemplate.Triggers>
                <!-- 工作台隐藏关闭按钮 -->
                <DataTrigger Binding="{Binding PageName}" Value="工作台">
                    <Setter TargetName="btnClose" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧侧边栏 -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0 1 1 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 顶部Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16 24" VerticalAlignment="Center">
                    <Ellipse Width="36" Height="36" Fill="#297BFF"/>
                    <TextBlock Text="XX后台管理系统" FontSize="19" FontWeight="SemiBold" Margin="10 0 0 0" Foreground="#222"/>
                </StackPanel>

                <!-- 侧边菜单 -->
                <StackPanel Grid.Row="1" Margin="0 10">
                    <RadioButton x:Name="rbWork" GroupName="MenuGroup" Checked="Menu_Checked" Tag="Work"
                                 FontSize="16" Padding="16 12" Foreground="#333"
                                 Template="{StaticResource SideMenuBtn}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🏠" FontSize="18"/>
                            <TextBlock Text="工作台" Margin="12 0 0 0"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="rbSystem" GroupName="MenuGroup" Checked="Menu_Checked" Tag="System"
                                 FontSize="16" Padding="16 12" Foreground="#333"
                                 Template="{StaticResource SideMenuBtn}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙️" FontSize="18"/>
                            <TextBlock Text="系统管理" Margin="12 0 0 0"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="rbLog" GroupName="MenuGroup" Checked="Menu_Checked" Tag="Log"
                                 FontSize="16" Padding="16 12" Foreground="#333"
                                 Template="{StaticResource SideMenuBtn}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📃" FontSize="18"/>
                            <TextBlock Text="日志管理" Margin="12 0 0 0"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- 退出登录 -->
                <StackPanel Grid.Row="3" Margin="16 0 16 30">
                    <Button Content="退出登录" FontSize="15" Padding="16 12" Background="Transparent"
                            Foreground="#F53F3F" HorizontalAlignment="Left" Click="BtnLogout_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdWrap" Padding="{TemplateBinding Padding}" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="👤" FontSize="18" Foreground="#F53F3F"/>
                                        <ContentPresenter VerticalAlignment="Center" Margin="12 0 0 0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdWrap" Property="Background" Value="#FFF0F0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 右侧主区域 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部面包屑标签栏 -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0 0 0 1">
                <Grid Margin="30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- 面包屑横向列表 -->
                    <ItemsControl x:Name="icBreadCrumb" Grid.Column="0" 
                                  ItemsPanel="{StaticResource BreadPanel}" 
                                  ItemTemplate="{StaticResource BreadCrumbItemTemplate}"/>
                    <!-- 右侧用户信息 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10">
                        <TextBlock Text="管理员" Foreground="#666"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 页面容器 -->
            <Frame x:Name="frameMain" Grid.Row="1" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>