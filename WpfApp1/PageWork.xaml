<Page x:Class="WpfApp1.PageWork"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F7F8FA">
    <ScrollViewer Margin="30" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="25">
            <UniformGrid Columns="4" Rows="1" Margin="20">
                <Border Background="White" CornerRadius="10" Padding="20">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="总用户数" FontSize="16" Foreground="#666"/>
                            <TextBlock Text="0" FontSize="32" FontWeight="Bold" Margin="0 8 0 0"/>
                            <TextBlock Text="+12%" Foreground="#00B42A" FontSize="14"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Width="48" Height="48" Background="#E8F3FF" CornerRadius="24">
                            <TextBlock Text="👥" FontSize="24" Foreground="#297BFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DockPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Padding="20">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="活跃用户" FontSize="16" Foreground="#666"/>
                            <TextBlock Text="0" FontSize="32" FontWeight="Bold" Margin="0 8 0 0"/>
                            <TextBlock Text="+8%" Foreground="#00B42A" FontSize="14"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Width="48" Height="48" Background="#E6FFE6" CornerRadius="24">
                            <TextBlock Text="🗨️" FontSize="24" Foreground="#00B42A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DockPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Padding="20">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="今日访问" FontSize="16" Foreground="#666"/>
                            <TextBlock Text="1,234" FontSize="32" FontWeight="Bold" Margin="0 8 0 0"/>
                            <TextBlock Text="+5%" Foreground="#00B42A" FontSize="14"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Width="48" Height="48" Background="#FFF7E6" CornerRadius="24">
                            <TextBlock Text="📑" FontSize="24" Foreground="#FF7D00" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DockPanel>
                </Border>
                <Border Background="White" CornerRadius="10" Padding="20">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="系统消息" FontSize="16" Foreground="#666"/>
                            <TextBlock Text="56" FontSize="32" FontWeight="Bold" Margin="0 8 0 0"/>
                            <TextBlock Text="+2" Foreground="#00B42A" FontSize="14"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Width="48" Height="48" Background="#FFE8E8" CornerRadius="24">
                            <TextBlock Text="📩" FontSize="24" Foreground="#F53F3F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0 0 20 0">
                    <StackPanel>
                        <TextBlock Text="访问趋势" FontSize="18" FontWeight="SemiBold" Margin="0 0 15 0"/>
                        <Border Height="260" Background="#F7F8FA"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20" Margin="0 0 0 20">
                    <StackPanel>
                        <TextBlock Text="最近活动" FontSize="18" FontWeight="SemiBold" Margin="0 0 15 0"/>
                        <StackPanel Margin="18">
                            <Border Padding="10" Background="#F7F8FA" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="用户登录" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="管理员 admin 登录系统" Foreground="#666"/>
                                    <TextBlock Text="06-29 14:53" FontSize="12" Foreground="#999"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="10" Background="#F7F8FA" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="数据更新" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="用户数据已同步更新" Foreground="#666"/>
                                    <TextBlock Text="06-29 14:43" FontSize="12" Foreground="#999"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="10" Background="#F7F8FA" CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="系统备份" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="数据库备份已完成" Foreground="#666"/>
                                    <TextBlock Text="06-29 12:58" FontSize="12" Foreground="#999"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="White" CornerRadius="10" Padding="20">
                <StackPanel>
                    <TextBlock Text="快捷操作" FontSize="18" FontWeight="SemiBold" Margin="0 0 20 0"/>
                    <UniformGrid Columns="4" Margin="30">
                        <Button Background="Transparent" BorderThickness="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="60" Height="60" Background="#E6FFE6" CornerRadius="30">
                                    <TextBlock Text="➕" FontSize="28" Foreground="#00B42A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="添加用户" Margin="8 0 0 0"/>
                            </StackPanel>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="60" Height="60" Background="#FFF7E6" CornerRadius="30">
                                    <TextBlock Text="⚙️" FontSize="28" Foreground="#FF7D00" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="系统设置" Margin="8 0 0 0"/>
                            </StackPanel>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="60" Height="60" Background="#E8F3FF" CornerRadius="30">
                                    <TextBlock Text="💾" FontSize="28" Foreground="#297BFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="数据备份" Margin="8 0 0 0"/>
                            </StackPanel>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="60" Height="60" Background="#F0F2F5" CornerRadius="30">
                                    <TextBlock Text="📋" FontSize="28" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="查看日志" Margin="8 0 0 0"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>