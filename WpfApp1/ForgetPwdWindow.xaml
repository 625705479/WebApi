<Window x:Class="WpfApp1.ForgetPwdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="忘记密码"
        Width="1300" Height="820"
        WindowStartupLocation="CenterScreen"
        Background="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧插画区域 -->
        <Border Grid.Column="0" Background="#f8f9fa">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                
            </StackPanel>
        </Border>

        <!-- 右侧找回密码表单 -->
        <StackPanel Grid.Column="1" Width="540" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="找回密码" FontSize="42" FontWeight="SemiBold" Foreground="#222" Margin="0 0 0 12"/>
            <TextBlock Text="输入账号信息重置登录密码" FontSize="15" Foreground="#777" Margin="0 0 0 40"/>

            <!-- 用户名 -->
            <TextBlock Text="用户名" FontSize="16" Foreground="#444" Margin="0 0 0 8"/>
            <TextBox x:Name="txtUserName" FontSize="16" Padding="12 10" Margin="0 0 0 22" BorderThickness="1" BorderBrush="#ddd">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="👤" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Content="×" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#999" Click="ClearUserName"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>

            <!-- 绑定手机号 -->
            <TextBlock Text="绑定手机号" FontSize="16" Foreground="#444" Margin="0 0 0 8"/>
            <Grid Margin="0 0 0 22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtPhone" FontSize="16" Padding="12 10" BorderThickness="1" BorderBrush="#ddd">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="📱" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
                <Button Grid.Column="1" x:Name="btnCode" Content="获取验证码" Margin="12 0 0 0" FontSize="14" Foreground="White" Height="44" Click="GetVerifyCode">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2678ff"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1d68e0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- 短信验证码 -->
            <TextBlock Text="短信验证码" FontSize="16" Foreground="#444" Margin="0 0 0 8"/>
            <TextBox x:Name="txtCode" FontSize="16" Padding="12 10" Margin="0 0 0 22" BorderThickness="1" BorderBrush="#ddd">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔢" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>

            <!-- 新密码 -->
            <TextBlock Text="设置新密码" FontSize="16" Foreground="#444" Margin="0 0 0 8"/>
            <PasswordBox x:Name="pwdNew" FontSize="16" Padding="12 10" Margin="0 0 0 22" BorderThickness="1" BorderBrush="#ddd">
                <PasswordBox.Template>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔒" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </PasswordBox.Template>
            </PasswordBox>

            <!-- 确认新密码 -->
            <TextBlock Text="确认新密码" FontSize="16" Foreground="#444" Margin="0 0 0 8"/>
            <PasswordBox x:Name="pwdConfirmNew" FontSize="16" Padding="12 10" Margin="0 0 0 30" BorderThickness="1" BorderBrush="#ddd">
                <PasswordBox.Template>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔒" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </PasswordBox.Template>
            </PasswordBox>

            <!-- 重置密码按钮 -->
            <Button x:Name="btnReset" Content="重置密码" FontSize="18" Foreground="White" Height="56" BorderThickness="0" Click="ResetPassword">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2678ff"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1d68e0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- 返回登录入口 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 30 0 0">
                <TextBlock Text="记起密码了？" FontSize="14" Foreground="#666"/>
                <TextBlock Text="返回登录" FontSize="14" Foreground="#2678ff" Margin="6 0 0 0" Cursor="Hand" MouseLeftButtonDown="BackToLogin"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>